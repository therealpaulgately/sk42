# SK42 Command Center — environment variables
# Copy to .env.local and fill in values

# Site URL (used for OAuth redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Set to true to preview UI without Supabase auth (development only)
NEXT_PUBLIC_DEV_SKIP_AUTH=true

# Supabase — create project at https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side only (never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=

# Warpath data source (server-side ingestion only)
WARPATH_RANKING_URL=https://yx.dmzgame.com/intl_warpath/rank_pid

# Optional: cron secret for scheduled sync endpoint
SYNC_CRON_SECRET=
